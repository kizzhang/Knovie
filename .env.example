# ===========================
# Knovie (知频) 环境变量
# ===========================

# --- LLM & YouTube Transcription ---
GOOGLE_GENERATIVE_AI_API_KEY=   # Gemini API Key（https://aistudio.google.com/apikey）
                                # 同时用于 AI 对话和 YouTube 视频直接转录

# --- Backend ---
BACKEND_URL=http://localhost:8000  # Python 后端地址

# --- Database ---
DATABASE_URL=                  # PostgreSQL（部署时用，如 Supabase 连接串）
DB_TYPE=sqlite                 # sqlite（开发）| postgres（生产）

# --- Transcription (Fallback) ---
GROQ_API_KEY=                  # Groq Whisper API（https://console.groq.com）作为 B站 及 Gemini 不可用时的后备
QWEN_API_KEY=                  # 通义千问 ASR（备选）

# --- Web Search (Chat 工具调用用) ---
SERPER_API_KEY=                # https://serper.dev（免费 2500 次/月）
# 或
# TAVILY_API_KEY=              # https://tavily.com（免费 1000 次/月）

# --- Platform Credentials ---
# B站 Cookie（可选，提高 API 额度）
BILIBILI_SESSDATA=

# --- Security ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3003  # CORS 允许的前端域名
RATE_LIMIT_ENABLED=false       # 启用 IP 速率限制
RATE_LIMIT_RPM=120             # 每 IP 每分钟最大请求数

# --- Image Cache ---
# 图片缓存目录（默认 backend/cache/images）
IMAGE_CACHE_DIR=

# 字幕缓存目录（默认 backend/cache/subtitles）
SUBTITLE_CACHE_DIR=

# 音频缓存目录（默认 backend/cache/audio）
AUDIO_CACHE_DIR=

# --- Auth (预留，未实现) ---
# AUTH_ENABLED=false
# AUTH_SECRET=
